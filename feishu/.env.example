# 把本文件复制为 .env 再填写，.env 不要提交到 git

# 自建应用凭证（开发者后台 -> 凭证与基础信息）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 当前仓库对应的飞书页面 token（每个仓库只改这一行）
# 从 URL 取最后一段：https://xxx.feishu.cn/wiki/<这里>
# ⚠ 重要：.env 里的值是 post-commit 钩子的默认目标
#   在 PowerShell 里用 $env:FEISHU_WIKI_TOKEN=xxx 临时切换时，
#   该值会被 git 钩子继承并覆盖 .env，导致推送到临时页面。
#   测试完毕后务必在 .env 里写回正确的 token。
FEISHU_WIKI_TOKEN=your_wiki_token_here

# 如果是自建应用访问第三方企业，才需要改；默认留空即可
FEISHU_OPEN_DOMAIN=https://open.feishu.cn
